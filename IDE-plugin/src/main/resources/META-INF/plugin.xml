<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN, cannot be changed between the plugin versions. -->
    <id>org.example.IDE-plugin</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
    <name>IDE-plugi</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor url="https://www.yourcompany.com">YourCompany</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
    <description><![CDATA[
        Enter short description for your plugin here.<br>
        <em>most HTML tags may be used</em>
    ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->

    <depends>com.intellij.java</depends>
    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true" />
    </extensions>

    <resource-bundle>messages.MyMessageBundle</resource-bundle>
    <!-- Extensions defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <codeInsight.lineMarkerProvider
                language="kotlin"
                implementationClass="com.plugin.LineMarkerProviderCommand"/>
        <codeInsight.lineMarkerProvider
                language="kotlin"
                implementationClass="com.plugin.EventLineMarkerProvider"/>
    </extensions>

    <actions>
        <group id = "Navigation" text = "Navigation" popup="true" icon="AllIcons.Actions.Search">
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            <action id="Emission"
                    class="com.plugin.EmissionAction"
                    text="Go to Emission">
                <keyboard-shortcut first-keystroke="control alt M" keymap="$default"/>
            </action>

            <action id="Processing"
                    class="com.plugin.ProcessingAction"
                    text="Go to Processing">
                <keyboard-shortcut first-keystroke="control alt K" keymap="$default"/>
            </action>
        </group>
        <group id = "Event.Navigation" text = "Event Navigation" popup="true" icon="AllIcons.Actions.Search">
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="Navigation"/>
            <action id="Event.Emission"
                    class="com.plugin.EventEmissionAction"
                    text="Go to Emission">
                <keyboard-shortcut first-keystroke="control alt E" keymap="$default"/>
            </action>

            <action id="Event.Processing"
                    class="com.plugin.EventProcessingAction"
                    text="Go to Processing">
                <keyboard-shortcut first-keystroke="control alt P" keymap="$default"/>
            </action>
        </group>
    </actions>
</idea-plugin>